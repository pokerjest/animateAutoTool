# Server Configuration
server:
  port: 8306
  mode: debug # debug or release
  public_url: "" # strongly recommended for reverse-proxy/public access, e.g. https://anime.example.com
  # headless: true # optional; leave unset to use the platform default (Windows tray=false, macOS/Linux headless=true)
  trusted_proxies: # only add IPs/CIDRs for reverse proxies you control
    - 127.0.0.1
    - ::1

# Database Configuration
database:
  path: data/animate.db

# Logging
log:
  level: info

# Authentication
auth:
  secret_key: "" # recommended: set a stable random value; if blank, the app falls back to data/bootstrap/auth_secret

# Managed sidecars
managed_services:
  download_missing: false # set true if you want AList/Jellyfin to auto-download when missing
